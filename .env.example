# ================================================================
# CONFIGURACIÓN - Redis + PostgreSQL
# ================================================================
# Copiar este archivo a .env y rellenar con tus valores

# REDIS
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# POSTGRESQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=comunidad_db
DB_USER=postgres
DB_PASSWORD=postgres
DB_POOL_SIZE=10

# NODE.JS / APP
PORT=3000
NODE_ENV=development

# LOGGING
LOG_LEVEL=info
LOG_FORMAT=json

# CACHE
CACHE_TTL_PROFILE=300          # 5 minutos
CACHE_TTL_FEED=60              # 1 minuto
CACHE_TTL_CONFIG=1800          # 30 minutos

# PERFORMANCE
ENABLE_CACHE=true
CACHE_FALLBACK_ON_ERROR=true   # Si Redis falla, usar BD
